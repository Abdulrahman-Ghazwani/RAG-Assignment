OPENAI_API_KEY=your_key_here

# Chroma (use CHROMA_HOST=chromadb when the app runs in Docker Compose)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=rag_documents

Optional — indexing speed (defaults: 128 and 4). Lower if OpenAI rate-limits you.
EMBEDDING_BATCH_SIZE=128
EMBEDDING_MAX_PARALLEL=4
